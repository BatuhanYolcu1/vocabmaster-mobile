{
  "expo": {
    "name": "VocabMaster - Kelime Öğren",
    "slug": "vocabmaster-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vocabmastermobile",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.vocabmaster.mobile",
      "buildNumber": "1",
      "supportsTabletMode": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Telaffuz egzersizleri için mikrofon gereklidir.",
        "NSSpeechRecognitionUsageDescription": "Konuşma modunda sesi değerlendirmek için kullanılır."
      }
    },
    "android": {
      "package": "com.vocabmaster.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#5B4CF5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5B4CF5",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#5B4CF5"
        }
      ]
    ],
    "privacy": "https://batuhanyolcu1.github.io/vocabmaster-mobile/privacy.html",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
